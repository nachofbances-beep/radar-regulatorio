# Copia este fichero a `.env` y rellena los valores.

# Clave secreta de Flask (genera una cadena larga aleatoria)
FLASK_SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria

# Contraseña compartida para acceder a la web.
APP_PASSWORD=SaintPeter

# URL base pública de la web (se usa en los enlaces de baja del correo).
# En desarrollo local: http://127.0.0.1:5000
# En Render: https://tu-servicio.onrender.com
PUBLIC_BASE_URL=http://127.0.0.1:5000

# Conexión a la base de datos. Por defecto SQLite local.
# En Render se inyecta automáticamente la URL de PostgreSQL en DATABASE_URL.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Brevo (https://app.brevo.com/) — necesario para el envío real de correos.
# Si lo dejas vacío, los correos se "simulan" y se vuelcan a logs/emails_simulados.log
BREVO_API_KEY=
BREVO_SENDER_EMAIL=alertas@tu-dominio.com
BREVO_SENDER_NAME=Radar Regulatorio

# Hora (zona Europe/Madrid) a la que se ejecuta el job diario en local.
# (En Render se programa con cron job en UTC; ver render.yaml.)
DAILY_JOB_TIME=10:00

# Días que retrocede la ingesta y la ventana de "Novedades" mostrada en la web.
INGEST_LOOKBACK_DAYS=95
DISPLAY_WINDOW_DAYS=92

# Pon a 1 si quieres desactivar el scheduler interno (p. ej. cuando programes
# la ingesta desde fuera con cron de Windows o Render Cron Jobs).
# RADAR_DISABLE_SCHEDULER=1
